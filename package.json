{
  "name": "cplace-browser-extension",
  "version": "1.2.0",
  "private": true,
  "description": "Chrome/Edge extension that detects cplace pages and exposes optional modules.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:icons": "node scripts/build-icons.mjs",
    "package": "npm run build:icons && wxt zip && wxt zip -b firefox && wxt zip -b safari",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@webext-core/fake-browser": "^1.5.0",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.0",
    "vitest": "^4.1.7",
    "wxt": "^0.20.26"
  },
  "overrides": {
    "tmp": "^0.2.6",
    "uuid": "^14.0.0"
  }
}
